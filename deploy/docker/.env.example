# =============================================================================
# ENTERPRISE AGENTIC RAG — ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and customize for your deployment
# =============================================================================

# -----------------------------------------------------------------------------
# DOMAIN & TLS
# -----------------------------------------------------------------------------
DOMAIN=rag.yourcompany.com
ACME_EMAIL=admin@yourcompany.com
TRAEFIK_AUTH=admin:$2y$10$...  # htpasswd -nbB admin password

# -----------------------------------------------------------------------------
# HUGGINGFACE (for gated models: Llama, Gemma, etc.)
# -----------------------------------------------------------------------------
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=changeme_secure_password_here
KEYCLOAK_DB_PASSWORD=changeme_secure_password_here

# -----------------------------------------------------------------------------
# KEYCLOAK (Auth/RBAC)
# -----------------------------------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_secure_password_here
KEYCLOAK_HOSTNAME=keycloak.rag.yourcompany.com
KEYCLOAK_REALM=rag-platform
KEYCLOAK_CLIENT_SECRET=changeme_client_secret_here

# -----------------------------------------------------------------------------
# MINIO (S3-compatible object storage)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_secure_password_here

# -----------------------------------------------------------------------------
# MODEL SELECTION (Open Source Models)
# -----------------------------------------------------------------------------
# LLM Options (vLLM):
#   Qwen/Qwen2.5-32B-Instruct          # Best quality, needs 40GB VRAM
#   Qwen/Qwen2.5-14B-Instruct          # Best balance, needs 24GB VRAM
#   Qwen/Qwen2.5-7B-Instruct           # Fast, needs 16GB VRAM
#   meta-llama/Llama-3.1-8B-Instruct   # Good, needs 16GB VRAM (gated)
#   google/gemma-2-9b-it               # Good, needs 16GB VRAM (gated)
LLM_MODEL=Qwen/Qwen2.5-14B-Instruct

# VLM Options:
#   Qwen/Qwen2-VL-7B-Instruct          # Best quality, needs 24GB VRAM
#   Qwen/Qwen2-VL-2B-Instruct          # Good, needs 8GB VRAM
VLM_MODEL=Qwen/Qwen2-VL-7B-Instruct

# Embedding/Reranker (txtai):
EMBED_MODEL=BAAI/bge-m3
EMBED_DEVICE=cuda
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_DEVICE=cuda

# -----------------------------------------------------------------------------
# GPU CONFIGURATION
# -----------------------------------------------------------------------------
# For single GPU: "0"
# For multi-GPU: "0,1,2,3"
CUDA_VISIBLE_DEVICES=0

# -----------------------------------------------------------------------------
# LANGFUSE (LLM Observability)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
LANGFUSE_NEXTAUTH_SECRET=changeme_generate_secure_secret
LANGFUSE_SALT=changeme_generate_secure_salt
# Get from Langfuse UI after first login: Settings → API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# GRAFANA
# -----------------------------------------------------------------------------
GRAFANA_PASSWORD=changeme_secure_password_here

# -----------------------------------------------------------------------------
# RAG API SETTINGS
# -----------------------------------------------------------------------------
# Options: header (X-Tenant-ID), subdomain (tenant.rag.com), path (/tenant/...)
TENANT_RESOLUTION=header

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
ENABLE_VLM=true
ENABLE_MULTIMODAL=true
ENABLE_AGENTIC=true
ENABLE_GUARDRAILS=true
ENABLE_CACHING=true