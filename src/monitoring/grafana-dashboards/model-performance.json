{
  "dashboard": {
    "title": "Model Performance",
    "uid": "model-performance",
    "tags": ["rag", "models", "vllm", "performance"],
    "timezone": "utc",
    "panels": [
      {
        "id": 1,
        "title": "vLLM Request Latency",
        "type": "graph",
        "datasource": "vLLM",
        "targets": [
          {"expr": "histogram_quantile(0.50, rate(vllm_request_latency_seconds_bucket[5m]))", "legendFormat": "P50"},
          {"expr": "histogram_quantile(0.95, rate(vllm_request_latency_seconds_bucket[5m]))", "legendFormat": "P95"},
          {"expr": "histogram_quantile(0.99, rate(vllm_request_latency_seconds_bucket[5m]))", "legendFormat": "P99"}
        ],
        "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8}
      },
      {
        "id": 2,
        "title": "vLLM Tokens/sec",
        "type": "graph",
        "datasource": "vLLM",
        "targets": [
          {"expr": "rate(vllm_token_total[1m])", "legendFormat": "Output Tokens/s"},
          {"expr": "rate(vllm_prompt_token_total[1m])", "legendFormat": "Prompt Tokens/s"}
        ],
        "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8}
      },
      {
        "id": 3,
        "title": "GPU Memory Usage",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [{"expr": "nvidia_gpu_memory_used_bytes / nvidia_gpu_memory_total_bytes by (gpu)", "legendFormat": "GPU {{gpu}}"}],
        "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8}
      },
      {
        "id": 4,
        "title": "GPU Utilization",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [{"expr": "nvidia_gpu_utilization by (gpu)", "legendFormat": "GPU {{gpu}}"}],
        "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8}
      },
      {
        "id": 5,
        "title": "vLLM Queue Depth",
        "type": "graph",
        "datasource": "vLLM",
        "targets": [{"expr": "vllm_request_queue_depth", "legendFormat": "Queue Depth"}],
        "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8}
      },
      {
        "id": 6,
        "title": "Cache Hit Rate",
        "type": "graph",
        "datasource": "vLLM",
        "targets": [{"expr": "vllm_cache_hit_rate", "legendFormat": "KV Cache Hit Rate"}],
        "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8}
      }
    ],
    "time": {"from": "now-1h", "to": "now"},
    "refresh": "10s"
  }
}