{
  "dashboard": {
    "title": "RAG Platform Overview",
    "uid": "rag-overview",
    "tags": ["rag", "overview"],
    "timezone": "utc",
    "panels": [
      {
        "id": 1,
        "title": "Total Queries/sec",
        "type": "stat",
        "datasource": "Prometheus",
        "targets": [{"expr": "sum(rate(rag_queries_total[1m]))", "legendFormat": "QPS"}],
        "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4}
      },
      {
        "id": 2,
        "title": "Query Latency P50/P95/P99",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [
          {"expr": "histogram_quantile(0.50, rate(rag_query_latency_seconds_bucket[5m]))", "legendFormat": "P50"},
          {"expr": "histogram_quantile(0.95, rate(rag_query_latency_seconds_bucket[5m]))", "legendFormat": "P95"},
          {"expr": "histogram_quantile(0.99, rate(rag_query_latency_seconds_bucket[5m]))", "legendFormat": "P99"}
        ],
        "gridPos": {"x": 6, "y": 0, "w": 12, "h": 8}
      },
      {
        "id": 3,
        "title": "Error Rate by Tenant",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [{"expr": "rate(rag_queries_total{status=\"error\"}[5m]) by (tenant)", "legendFormat": "{{tenant}}"}],
        "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4}
      },
      {
        "id": 4,
        "title": "Active Tenants",
        "type": "stat",
        "datasource": "Prometheus",
        "targets": [{"expr": "count(rag_active_tenants)", "legendFormat": "Tenants"}],
        "gridPos": {"x": 0, "y": 4, "w": 6, "h": 4}
      },
      {
        "id": 5,
        "title": "Queries by Tenant",
        "type": "piechart",
        "datasource": "Prometheus",
        "targets": [{"expr": "sum by (tenant) (rate(rag_queries_total[5m]))", "legendFormat": "{{tenant}}"}],
        "gridPos": {"x": 6, "y": 8, "w": 12, "h": 8}
      },
      {
        "id": 6,
        "title": "Ingestion Rate",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [{"expr": "rate(rag_ingestions_total[5m])", "legendFormat": "Ingestions/sec"}],
        "gridPos": {"x": 18, "y": 4, "w": 6, "h": 4}
      }
    ],
    "time": {"from": "now-1h", "to": "now"},
    "refresh": "10s"
  }
}