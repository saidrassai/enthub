name: CI

on:
  pull_request:
    branches: [main]
  push:
    branches: [main]

jobs:
  lint-type-test:
    name: Lint, Type, Test, Security
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.13"

      - name: Install deps
        run: |
          python -m pip install --upgrade pip
          pip install ruff mypy pytest bandit

      - name: Ruff lint
        run: ruff check src/ tests/

      - name: MyPy type check
        run: mypy src/
        continue-on-error: true  # disable once types are stable

      - name: Pytest
        run: pytest tests/ -q

      - name: Bandit security scan
        run: bandit -qr src/ -ll

  enterprise-rag-review:
    name: Enterprise RAG Review Gate
    runs-on: ubuntu-latest
    needs: lint-type-test
    steps:
      - uses: actions/checkout@v4

      - name: Run enterprise-rag-review skill contract check
        run: |
          #!/usr/bin/env bash
          set -euo pipefail
          FAIL=0

          # 1. Debt ticket linkage required when architecture exceptions exist
          if git diff origin/main...HEAD -- '*.py' | grep -qE 'DEBT-|debt'; then
            if ! git log -1 --format=%B | grep -qiE '(DEBT-[0-9]+|closes #[0-9]+)'; then
              echo "::warning::Architecture change present without linked DEBT ticket."
              FAIL=1
            fi
          fi

          # 2. No reranker bypass in pipeline or retrieval code
          if git diff origin/main...HEAD -- '*.py' | grep -qi 'reranker.*=.*False'; then
            if ! git log -1 --format=%B | grep -qiE 'DEBT-[0-9]+'; then
              echo "::error::Reranker disable detected without DEBT ticket with R@5 regression."
              FAIL=1
            fi
          fi

          # 3. No banned anti-pattern imports
          if git diff origin/main...HEAD -- '*.py' | grep -qiE 'import (jwt|pyjwt|oidc)'; then
            echo "::error::Custom JWT import detected. Use OIDC first-class auth."
            FAIL=1
          fi

          # 4. Contract interfaces exist for new modules
          for path in $(git diff --name-only origin/main...HEAD -- 'src/**/*.py' | grep -E 'src/(ingest|retrieve|govern)/'); do
            module=$(echo "$path" | sed -E 's|/([^/]+)/[^/]+\.py|\1|')
            if ! git ls-tree -r --name-only HEAD | grep -qE "src/$module/.*protocol|src/$module/.*schema|src/$module/__init__"; then
              echo "::warning::New module '$module' lacks declared interface (protocol or schema)."
              FAIL=1
            fi
          done

          # 5. PR must link a Linear ticket (conventional commit hook)
          PR_BODY=$(jq -r '.pull_request.body // ""' "$GITHUB_EVENT_PATH")
          if ! echo "$PR_BODY" | grep -qiE '(linear|ticket|issue|[A-Z]+-[0-9]+)'; then
            echo "::warning::PR description does not reference a Linear ticket."
            FAIL=1
          fi

          if [ "$FAIL" -ne 0 ]; then
            echo "Enterprise RAG review gate: FAILED — see warnings/errors above."
            exit 1
          fi
          echo "Enterprise RAG review gate: PASSED."

  docker-build:
    name: Docker Build Smoke Test
    runs-on: ubuntu-latest
    needs: [lint-type-test, enterprise-rag-review]
    steps:
      - uses: actions/checkout@v4
      - name: Build docker-compose services
        run: docker compose -f deploy/docker/docker-compose.yml build
      - name: Start services
        run: docker compose -f deploy/docker/docker-compose.yml up -d
      - name: Wait for API health
        run: |
          for i in $(seq 1 30); do
            if curl -sf http://localhost:8000/healthz >/dev/null 2>&1; then
              echo "API healthy."
              exit 0
            fi
            sleep 2
          done
          echo "::error::API did not become healthy within 60s."
          exit 1
      - name: Tear down
        if: always()
        run: docker compose -f deploy/docker/docker-compose.yml down -v
